# ===========================================
# Aula Virtual UAndina - Environment Variables
# ===========================================
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control!

# Your UAndina campus credentials
MOODLE_USERNAME=your_student_code_here
MOODLE_PASSWORD=your_password_here

# UAndina Moodle URL (do not change)
MOODLE_URL=https://campus.uandina.edu.pe

# Token will be auto-filled after running get_uandina_token.py
# DO NOT share this token with anyone!
MOODLE_TOKEN=
